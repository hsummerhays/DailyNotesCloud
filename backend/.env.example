PORT=5000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dailynotescloud?schema=public

# Comma-separated list of origins allowed to call this API.
CORS_ORIGIN=http://localhost:3000

# Required. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# The app refuses to start without this when NODE_ENV=production.
JWT_SECRET=

# Optional. Leave unset to disable Google Sign-In (the /api/auth/google
# route fails closed with 503 rather than accepting unverified tokens).
GOOGLE_CLIENT_ID=
